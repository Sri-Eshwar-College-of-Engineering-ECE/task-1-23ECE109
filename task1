#!/bin/bash
cat>access_log.txt <<EOF
192.168.1.10 job-apply user1
192.168.1.10 job-apply user2
192.168.1.10 job-apply user3
192.168.1.10 job-apply user4
192.168.1.10 job-apply user5
192.168.1.10 job-apply user6
192.168.1.20 login user7
EOF

declare -A count
while IFS= read -r line
do
    ip=$(echo "$line"|awk '{print $1}')
    action=$(echo "$line"|awk '{print $2}')
    if [ "$action" = "job-apply" ]
    then
        ((count["$ip"]++))
    fi
done <access_log.txt

for ip in "${!count[@]}"
do
    if [ "${count[$ip]}" -gt 5 ]
    then
        echo "$ip : ${count[$ip]}"
    fi
done


